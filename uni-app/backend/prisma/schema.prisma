generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum CategoryType {
  NEWS
  RESOURCE
  COMMON
}

enum ResourceType {
  LINK
  FILE
  TEXT
}

model User {
  id           String   @id @default(cuid())
  fullName     String
  email        String   @unique
  passwordHash String
  role         Role     @default(STUDENT)
  faculty      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  news         News[]
  deviceTokens DeviceToken[]

  @@map("users")
}

model Category {
  id        String       @id @default(cuid())
  name      String
  type      CategoryType @default(COMMON)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  news      News[]
  resources Resource[]

  @@map("categories")
}

model News {
  id               String    @id @default(cuid())
  title            String
  shortDescription String
  content          String
  imageUrl         String?
  gallery          String[]  @default([])
  isPublished      Boolean   @default(false)
  publishedAt      DateTime?
  authorId         String
  categoryId       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  author   User      @relation(fields: [authorId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])

  @@map("news")
}

model Resource {
  id          String       @id @default(cuid())
  title       String
  description String
  type        ResourceType @default(LINK)
  url         String?
  fileUrl     String?
  categoryId  String?
  isPublished Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  category Category? @relation(fields: [categoryId], references: [id])

  @@map("resources")
}

model Notification {
  id                String   @id @default(cuid())
  title             String
  body              String
  relatedEntityType String?
  relatedEntityId   String?
  sentAt            DateTime @default(now())
  createdAt         DateTime @default(now())

  @@map("notifications")
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("device_tokens")
}
